{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "fleetshell-client",
	"version": "0.4.0",
	"identifier": "com.fleetshell.client",
	"build": {
		"frontendDist": "../build",
		"devUrl": "http://localhost:5173",
		"beforeDevCommand": "npm run dev",
		"beforeBuildCommand": "npm run build"
	},
	"app": {
		"windows": [
			{
				"title": "FleetShell",
				"width": 800,
				"height": 600,
				"resizable": true,
				"fullscreen": false,
				"visible": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": ["nsis", "app", "dmg", "deb", "rpm", "appimage"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"android": {
			"debugApplicationIdSuffix": ".debug"
		},
		"windows": {
			"nsis": {
				"installMode": "currentUser",
				"template": "nsis/installer.nsi",
				"displayLanguageSelector": false,
				"languages": ["English"]
			}
		}
	},
	"plugins": {
		"deep-link": {
			"desktop": {
				"schemes": ["fleetshell"]
			}
		}
	}
}
